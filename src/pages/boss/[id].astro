---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { bossesData } from '../../data/bosses.js';

export async function getStaticPaths() {
  return bossesData.map(boss => ({
    params: { id: boss.id.toString() },
    props: { boss }
  }));
}

const { boss } = Astro.props;

// Prev / Next navigation
const currentIndex = bossesData.findIndex(b => b.id === boss.id);
const prevBoss = currentIndex > 0 ? bossesData[currentIndex - 1] : null;
const nextBoss = currentIndex < bossesData.length - 1 ? bossesData[currentIndex + 1] : null;

// Маппинг классов для подсветки типов способностей
const getTypeClass = (type: string) => {
  const t = type.toLowerCase();
  if (t.includes('теневой') || t.includes('тьма') || t.includes('тьмы')) return 'type-shadow';
  if (t.includes('огонь') || t.includes('огненный') || t.includes('пепел')) return 'type-fire';
  if (t.includes('лед') || t.includes('ледяной') || t.includes('холод')) return 'type-ice';
  if (t.includes('природный') || t.includes('природы') || t.includes('грязь')) return 'type-nature';
  if (t.includes('физический') || t.includes('физ')) return 'type-phys';
  return 'type-mech';
};

// Переводы категорий лута для заголовков
const lootCategories = [
  { key: 'cloth', title: 'Ткань' },
  { key: 'leather', title: 'Кожа' },
  { key: 'mail', title: 'Кольчуга' },
  { key: 'plate', title: 'Латы' },
  { key: 'jewelry', title: 'Бижутерия' },
  { key: 'weapons', title: 'Оружие' },
  { key: 'misc', title: 'Разное' },
  { key: 'junk', title: 'Мусор' }
];
---

<Layout title={boss.name} description={boss.summary}>
  <Sidebar activeId={boss.id} />
  
  <main class="main-content">
    <div class="boss-detail-container">
      
      <!-- Панель выбора сложности (Normal / Heroic) -->
      <div class="difficulty-selector" style="display: flex; gap: 15px; margin-bottom: 25px; align-items: center; background: var(--bg-secondary); border: 1px solid var(--border-color); padding: 12px 20px; border-radius: 12px; max-width: max-content;">
        <span style="font-weight: 700; font-size: 0.85rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px;">Сложность рейда:</span>
        <div style="display: flex; background: rgba(0,0,0,0.2); padding: 3px; border-radius: 8px; border: 1px solid var(--border-color);">
          <button class="diff-btn active" data-diff-target="normal" style="background: var(--accent-purple); border: none; color: #fff; padding: 6px 16px; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s;">Обычный (Normal)</button>
          <button class="diff-btn" data-diff-target="heroic" style="background: transparent; border: none; color: var(--text-secondary); padding: 6px 16px; border-radius: 6px; font-weight: 600; cursor: pointer; transition: all 0.2s;">Героический (Heroic)</button>
        </div>
      </div>

      <!-- Грид шапки босса с изображением и видео-кнопкой -->
      <div class="boss-header-grid">
        <div class="boss-info-panel">
          <span class="zone-badge">{boss.zone}</span>
          <div class="boss-title-row">
            <h1 class="boss-main-title">{boss.name}</h1>
            <span class="boss-sub-title">{boss.englishName}</span>
          </div>
          <p class="boss-summary-text">{boss.summary}</p>
          
          <!-- Обычные ключевые фазы -->
          <div class="boss-phases-box" data-diff-content="normal" style="display: block;">
            <div class="phases-title">Ключевые фазы и триггеры</div>
            <ul class="phases-list" style="list-style: none; padding: 0; margin: 12px 0 0 0; display: flex; flex-direction: column; gap: 8px;">
              {boss.normal.criticalPhases.map(phase => (
                <li style="display: flex; gap: 10px; line-height: 1.5; font-size: 0.95rem; color: var(--text-secondary); align-items: flex-start;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--accent-purple)" style="flex-shrink: 0; margin-top: 3px;" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                  <span>{phase}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Героические ключевые фазы -->
          <div class="boss-phases-box" data-diff-content="heroic" style="display: none; border-left-color: var(--color-dps); background: rgba(248, 113, 113, 0.02);">
            <div class="phases-title" style="color: var(--color-dps);">Ключевые изменения в героическом режиме</div>
            <ul class="phases-list" style="list-style: none; padding: 0; margin: 12px 0 0 0; display: flex; flex-direction: column; gap: 8px;">
              {boss.heroic.criticalPhases.map(phase => (
                <li style="display: flex; gap: 10px; line-height: 1.5; font-size: 0.95rem; color: var(--text-secondary); align-items: flex-start;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-dps)" style="flex-shrink: 0; margin-top: 3px;" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                  <span>{phase}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <div class="boss-action-panel" style="flex-shrink: 0;">
          {boss.image && (
            <div class="boss-image-container" style="width: 100%; aspect-ratio: 16/10; border-radius: 12px; overflow: hidden; margin-bottom: 20px; border: 1px solid var(--border-color); box-shadow: 0 4px 20px rgba(0,0,0,0.4);">
              <img src={boss.image} alt={boss.name} loading="lazy" width="640" height="400" style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.95);" />
            </div>
          )}
          <div class="action-title">Видео-тактика</div>
          <p class="action-desc" style="font-size: 0.8rem; margin-bottom: 15px;">Посмотрите прохождение босса по описываемой тактике.</p>
          <a href={boss.videoLink} target="_blank" rel="noopener noreferrer" class="video-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
            Смотреть видео
          </a>
        </div>
      </div>
      
      <!-- Раздел способностей -->
      <section class="boss-section">
        <!-- Способности босса (Normal) -->
        <div data-diff-content="normal" style="display: block;">
          <h2 class="section-heading">Важные способности босса</h2>
          <div class="table-wrapper">
            <table class="abilities-table">
              <thead>
                <tr>
                  <th style="width: 30%">Способность</th>
                  <th style="width: 25%">Тип урона / Эффект</th>
                  <th style="width: 45%">Описание и противодействие</th>
                </tr>
              </thead>
              <tbody>
                {boss.normal.abilities.map(ability => (
                  <tr>
                    <td class="ability-name">{ability.name}</td>
                    <td>
                      <span class={`ability-type ${getTypeClass(ability.type)}`}>
                        {ability.type}
                      </span>
                    </td>
                    <td style="color: var(--text-secondary);">{ability.desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Способности босса (Heroic) -->
        <div data-diff-content="heroic" style="display: none;">
          <h2 class="section-heading" style="color: var(--color-dps);">Способности босса (Обычные + Героические)</h2>
          <div class="table-wrapper">
            <table class="abilities-table">
              <thead>
                <tr>
                  <th style="width: 30%">Способность</th>
                  <th style="width: 25%">Тип урона / Эффект</th>
                  <th style="width: 45%">Описание и противодействие</th>
                </tr>
              </thead>
              <tbody>
                {/* Обычные способности */}
                {boss.normal.abilities.map(ability => (
                  <tr>
                    <td class="ability-name">{ability.name}</td>
                    <td>
                      <span class={`ability-type ${getTypeClass(ability.type)}`}>
                        {ability.type}
                      </span>
                    </td>
                    <td style="color: var(--text-secondary);">{ability.desc}</td>
                  </tr>
                ))}
                {/* Героические способности */}
                {boss.heroic.abilities.map(ability => (
                  <tr style="background: rgba(248, 113, 113, 0.03);">
                    <td class="ability-name" style="color: var(--color-dps);">{ability.name} <span style="font-size: 0.75rem; text-transform: uppercase; background: var(--color-dps-bg); padding: 2px 6px; border-radius: 4px; font-weight: 700; margin-left: 6px;">ХМ</span></td>
                    <td>
                      <span class="ability-type" style="background: var(--color-dps-bg); color: var(--color-dps); border: 1px solid rgba(248, 113, 113, 0.2)">
                        {ability.type}
                      </span>
                    </td>
                    <td style="color: var(--text-secondary);">{ability.desc}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Раздел ролей -->
      <section class="boss-section">
        <h2 class="section-heading">Тактические задачи по ролям</h2>
        <div class="role-tabs">
          <button class="role-tab-btn active" data-role="all">Все роли</button>
          <button class="role-tab-btn" data-role="tank">
            <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
            Танки
          </button>
          <button class="role-tab-btn" data-role="healer">
            <svg viewBox="0 0 24 24"><path d="M19 10.5h-5.5V5h-3v5.5H5v3h5.5V19h3v-5.5H19v-3z"/></svg>
            Целители
          </button>
          <button class="role-tab-btn" data-role="dps">
            <svg viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/></svg>
            Бойцы (ДД)
          </button>
          <button class="role-tab-btn" data-role="rl">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2-2 0-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.25z"/></svg>
            Рейд-лидер
          </button>
        </div>

        <!-- Роли (Normal) -->
        <div data-diff-content="normal" style="display: block;">
          <div class="roles-grid" data-roles-container="normal">
            <div class="role-card card-tank" data-card-role="tank">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                </div>
                <h3 class="role-card-title">Танки</h3>
              </div>
              <ul class="checklist">
                {boss.normal.tankActions.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="role-card card-healer" data-card-role="healer">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 10.5h-5.5V5h-3v5.5H5v3h5.5V19h3v-5.5H19v-3z"/></svg>
                </div>
                <h3 class="role-card-title">Целители</h3>
              </div>
              <ul class="checklist">
                {boss.normal.healerActions.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="role-card card-dps" data-card-role="dps">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 22h20L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/></svg>
                </div>
                <h3 class="role-card-title">Бойцы (ДД)</h3>
              </div>
              <ul class="checklist">
                {boss.normal.dpsActions.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="role-card card-rl" data-card-role="rl">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2-2 0-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.25z"/></svg>
                </div>
                <h3 class="role-card-title">Рейд-лидер (РЛ)</h3>
              </div>
              <ul class="checklist">
                {boss.normal.rlNotes.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>

        <!-- Роли (Heroic) -->
        <div data-diff-content="heroic" style="display: none;">
          <div class="roles-grid" data-roles-container="heroic">
            <div class="role-card card-tank" data-card-role="tank">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                </div>
                <h3 class="role-card-title">Танки (Героик)</h3>
              </div>
              <ul class="checklist">
                {boss.heroic.tankActions.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="role-card card-healer" data-card-role="healer">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 10.5h-5.5V5h-3v5.5H5v3h5.5V19h3v-5.5H19v-3z"/></svg>
                </div>
                <h3 class="role-card-title">Целители (Героик)</h3>
              </div>
              <ul class="checklist">
                {boss.heroic.healerActions.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="role-card card-dps" data-card-role="dps">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 22h20L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/></svg>
                </div>
                <h3 class="role-card-title">Бойцы (ДД - Героик)</h3>
              </div>
              <ul class="checklist">
                {boss.heroic.dpsActions.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="role-card card-rl" data-card-role="rl">
              <div class="role-card-header">
                <div class="role-icon-box">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2-2 0-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.25z"/></svg>
                </div>
                <h3 class="role-card-title">Рейд-лидер (Героик)</h3>
              </div>
              <ul class="checklist">
                {boss.heroic.rlNotes.map(action => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                    <span>{action}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Раздел классовых хитростей (Normal) -->
      <div data-diff-content="normal" style="display: block;">
        {boss.normal.classTricks && boss.normal.classTricks.length > 0 && (
          <section class="boss-section">
            <h2 class="section-heading">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-rl)" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle; margin-right: 10px;">
                <path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7zm2.85 11.1l-.85.6V16h-4v-2.3l-.85-.6C7.8 12.16 7 10.63 7 9c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.63-.8 3.16-2.15 4.1z"/>
              </svg>
              Классовые хитрости и фишки
            </h2>
            <div class="role-card card-rl" style="border-top: 4px solid var(--color-rl);">
              <ul class="checklist">
                {boss.normal.classTricks.map(trick => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-rl)" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                    </svg>
                    <span>{trick}</span>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </div>

      <!-- Раздел классовых хитростей (Heroic) -->
      <div data-diff-content="heroic" style="display: none;">
        {((boss.normal.classTricks && boss.normal.classTricks.length > 0) || (boss.heroic.classTricks && boss.heroic.classTricks.length > 0)) && (
          <section class="boss-section">
            <h2 class="section-heading" style="color: var(--color-dps);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-dps)" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle; margin-right: 10px;">
                <path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7zm2.85 11.1l-.85.6V16h-4v-2.3l-.85-.6C7.8 12.16 7 10.63 7 9c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.63-.8 3.16-2.15 4.1z"/>
              </svg>
              Классовые хитрости (Героик)
            </h2>
            <div class="role-card card-dps" style="border-top: 4px solid var(--color-dps);">
              <ul class="checklist">
                {boss.normal.classTricks && boss.normal.classTricks.map(trick => (
                  <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-dps)" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                    </svg>
                    <span>{trick}</span>
                  </li>
                ))}
                 {boss.heroic.classTricks && boss.heroic.classTricks.map(trick => (
                   <li class="checklist-item">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-dps)" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                    </svg>
                    <span>{trick} <span style="font-size: 0.7rem; color: var(--color-dps); text-transform: uppercase;">(Героик)</span></span>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </div>

      <!-- Раздел добычи (Loot) -->
      <section class="boss-section">
        <h2 class="section-heading">Таблица добычи (Loot)</h2>
        
        <!-- Обычный Лут -->
        <div data-diff-content="normal" style="display: block;">
          <div class="loot-grid">
            {lootCategories.map(category => (
              boss.loot.normal[category.key] && boss.loot.normal[category.key].length > 0 && (
                <div class="loot-category">
                  <div class="loot-category-title">{category.title}</div>
                  <ul class="loot-item-list">
                    {boss.loot.normal[category.key].map(item => (
                      <li>
                        <a href={`https://www.wowhead.com/mop-classic/ru/item=${item.id}`} target="_blank" rel="noopener noreferrer">
                          {item.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )
            ))}
          </div>
        </div>

        <!-- Героический Лут -->
        <div data-diff-content="heroic" style="display: none;">
          <div class="loot-grid">
            {lootCategories.map(category => (
              boss.loot.heroic[category.key] && boss.loot.heroic[category.key].length > 0 && (
                <div class="loot-category" style="border-color: rgba(248, 113, 113, 0.15);">
                  <div class="loot-category-title" style="color: var(--color-dps);">{category.title}</div>
                  <ul class="loot-item-list">
                    {boss.loot.heroic[category.key].map(item => (
                      <li>
                        <a href={`https://www.wowhead.com/mop-classic/ru/item=${item.id}`} target="_blank" rel="noopener noreferrer">
                          {item.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )
            ))}
          </div>
        </div>
      </section>

      <!-- Навигация между боссами -->
      <nav class="boss-nav-bar">
        <div class="boss-nav-prev">
          {prevBoss ? (
            <a href={`/boss/${prevBoss.id}`} class="boss-nav-link">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
              </svg>
              <div class="boss-nav-info">
                <span class="boss-nav-label">Предыдущий</span>
                <span class="boss-nav-name">{prevBoss.name}</span>
              </div>
            </a>
          ) : <div></div>}
        </div>
        <a href="/" class="boss-nav-all">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
          </svg>
          Все боссы
        </a>
        <div class="boss-nav-next">
          {nextBoss ? (
            <a href={`/boss/${nextBoss.id}`} class="boss-nav-link boss-nav-link--right">
              <div class="boss-nav-info" style="text-align: right;">
                <span class="boss-nav-label">Следующий</span>
                <span class="boss-nav-name">{nextBoss.name}</span>
              </div>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
              </svg>
            </a>
          ) : <div></div>}
        </div>
      </nav>

    </div>
  </main>
</Layout>

<style>
  /* Локальные стили для таблицы лута */
  .loot-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  .loot-category {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 20px;
    backdrop-filter: blur(10px);
    transition: all 0.3s ease;
  }
  .loot-category:hover {
    transform: translateY(-2px);
    border-color: rgba(157, 92, 255, 0.25);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  }
  .loot-category-title {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--accent-purple);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .loot-item-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 0;
    margin: 0;
  }
  .loot-item-list li {
    display: flex;
    align-items: center;
  }
  .loot-item-list a {
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    transition: transform 0.2s ease;
  }
  .loot-item-list a:hover {
    transform: translateX(4px);
  }
</style>

<script>
  // Клиентский переключатель сложности
  const diffButtons = document.querySelectorAll('[data-diff-target]');
  const diffContents = document.querySelectorAll('[data-diff-content]');

  diffButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Смена активного стиля кнопок переключателя
      diffButtons.forEach(b => {
        b.classList.remove('active');
        (b as HTMLElement).style.background = 'transparent';
        (b as HTMLElement).style.color = 'var(--text-secondary)';
      });
      btn.classList.add('active');
      (btn as HTMLElement).style.background = 'var(--accent-purple)';
      (btn as HTMLElement).style.color = '#fff';

      const targetDiff = btn.getAttribute('data-diff-target');

      // Смена отображаемого контента по сложности
      diffContents.forEach(content => {
        const contentDiff = content.getAttribute('data-diff-content');
        const element = content as HTMLElement;
        if (contentDiff === targetDiff) {
          element.style.display = 'block';
        } else {
          element.style.display = 'none';
        }
      });
      
      // Сброс активных вкладок ролей к значению "Все роли" при смене сложности
      const activeTabs = document.querySelectorAll('.role-tab-btn');
      activeTabs.forEach(t => {
        if (t.getAttribute('data-role') === 'all') {
          t.classList.add('active');
          (t as HTMLElement).click();
        } else {
          t.classList.remove('active');
        }
      });
    });
  });

  // Клиентское переключение вкладок ролей
  const tabButtons = document.querySelectorAll('.role-tab-btn');
  
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Находим текущую активную сложность
      const activeDiffBtn = document.querySelector('[data-diff-target].active');
      const diff = activeDiffBtn ? activeDiffBtn.getAttribute('data-diff-target') : 'normal';

      // Делаем кликнутую вкладку активной
      tabButtons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const role = btn.getAttribute('data-role');

      // Фильтруем карточки только внутри активного контейнера сложности
      const activeContainer = document.querySelector(`[data-diff-content="${diff}"] [data-roles-container]`);
      if (activeContainer) {
        const roleCards = activeContainer.querySelectorAll('[data-card-role]');
        roleCards.forEach(card => {
          const cardRole = card.getAttribute('data-card-role');
          const element = card as HTMLElement;
          if (role === 'all' || cardRole === role) {
            element.style.display = 'block';
          } else {
            element.style.display = 'none';
          }
        });
      }
    });
  });
</script>
