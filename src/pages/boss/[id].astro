---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { bossesData } from '../../data/bosses.js';

export async function getStaticPaths() {
  return bossesData.map(boss => ({
    params: { id: boss.id.toString() },
    props: { boss }
  }));
}

const { boss } = Astro.props;

// Маппинг классов для подсветки типов способностей
const getTypeClass = (type: string) => {
  const t = type.toLowerCase();
  if (t.includes('теневой') || t.includes('тьма') || t.includes('тьмы')) return 'type-shadow';
  if (t.includes('огонь') || t.includes('огненный') || t.includes('пепел')) return 'type-fire';
  if (t.includes('лед') || t.includes('ледяной') || t.includes('холод')) return 'type-ice';
  if (t.includes('природный') || t.includes('природы') || t.includes('грязь')) return 'type-nature';
  if (t.includes('физический') || t.includes('физ')) return 'type-phys';
  return 'type-mech';
};
---

<Layout title={boss.name} description={boss.summary}>
  <Sidebar activeId={boss.id} />
  
  <main class="main-content">
    <div class="boss-detail-container">
      
      <!-- Грид шапки босса с изображением и видео-кнопкой -->
      <div class="boss-header-grid">
        <div class="boss-info-panel">
          <span class="zone-badge">{boss.zone}</span>
          <div class="boss-title-row">
            <h1 class="boss-main-title">{boss.name}</h1>
            <span class="boss-sub-title">{boss.englishName}</span>
          </div>
          <p class="boss-summary-text">{boss.summary}</p>
          
          <div class="boss-phases-box">
            <div class="phases-title">Ключевые фазы и триггеры</div>
            <ul class="phases-list" style="list-style: none; padding: 0; margin: 12px 0 0 0; display: flex; flex-direction: column; gap: 8px;">
              {boss.criticalPhases.map(phase => (
                <li style="display: flex; gap: 10px; line-height: 1.5; font-size: 0.95rem; color: var(--text-secondary); align-items: flex-start;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--accent-purple)" style="flex-shrink: 0; margin-top: 3px;" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                  </svg>
                  <span>{phase}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        
        <div class="boss-action-panel">
          {boss.image && (
            <div class="boss-image-container" style="width: 100%; aspect-ratio: 16/10; border-radius: 12px; overflow: hidden; margin-bottom: 20px; border: 1px solid var(--border-color); box-shadow: 0 4px 20px rgba(0,0,0,0.4);">
              <img src={boss.image} alt={boss.name} style="width: 100%; height: 100%; object-fit: cover; filter: brightness(0.95);" />
            </div>
          )}
          <div class="action-title">Видео-тактика</div>
          <p class="action-desc" style="font-size: 0.8rem; margin-bottom: 15px;">Посмотрите прохождение босса по описываемой тактике.</p>
          <a href={boss.videoLink} target="_blank" rel="noopener noreferrer" class="video-btn">
            <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M8 5v14l11-7z"/>
            </svg>
            Смотреть видео
          </a>
        </div>
      </div>
      
      <!-- Раздел способностей -->
      <h2 class="section-heading">Важные способности босса</h2>
      <div class="table-wrapper">
        <table class="abilities-table">
          <thead>
            <tr>
              <th style="width: 30%">Способность</th>
              <th style="width: 25%">Тип урона / Эффект</th>
              <th style="width: 45%">Описание и противодействие</th>
            </tr>
          </thead>
          <tbody>
            {boss.abilities.map(ability => (
              <tr>
                <td class="ability-name">{ability.name}</td>
                <td>
                  <span class={`ability-type ${getTypeClass(ability.type)}`}>
                    {ability.type}
                  </span>
                </td>
                <td style="color: var(--text-secondary);">{ability.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Вкладки по ролям -->
      <h2 class="section-heading">Тактические задачи по ролям</h2>
      <div class="role-tabs">
        <button class="role-tab-btn active" data-role="all">Все роли</button>
        <button class="role-tab-btn" data-role="tank">
          <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
          Танки
        </button>
        <button class="role-tab-btn" data-role="healer">
          <svg viewBox="0 0 24 24"><path d="M19 10.5h-5.5V5h-3v5.5H5v3h5.5V19h3v-5.5H19v-3z"/></svg>
          Целители
        </button>
        <button class="role-tab-btn" data-role="dps">
          <svg viewBox="0 0 24 24"><path d="M12 2L2 22h20L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/></svg>
          Бойцы (ДД)
        </button>
        <button class="role-tab-btn" data-role="rl">
          <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2-2 0-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.25z"/></svg>
          Рейд-лидер
        </button>
      </div>

      <div class="roles-grid" id="roles-cards-container">
        <!-- Танки -->
        <div class="role-card card-tank" data-card-role="tank">
          <div class="role-card-header">
            <div class="role-icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
            </div>
            <h3 class="role-card-title">Танки</h3>
          </div>
          <ul class="checklist">
            {boss.tankActions.map(action => (
              <li class="checklist-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span>{action}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Целители -->
        <div class="role-card card-healer" data-card-role="healer">
          <div class="role-card-header">
            <div class="role-icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 10.5h-5.5V5h-3v5.5H5v3h5.5V19h3v-5.5H19v-3z"/></svg>
            </div>
            <h3 class="role-card-title">Целители</h3>
          </div>
          <ul class="checklist">
            {boss.healerActions.map(action => (
              <li class="checklist-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span>{action}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- ДД -->
        <div class="role-card card-dps" data-card-role="dps">
          <div class="role-card-header">
            <div class="role-icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 22h20L12 2zm0 3.99L19.53 19H4.47L12 5.99z"/></svg>
            </div>
            <h3 class="role-card-title">Бойцы (ДД)</h3>
          </div>
          <ul class="checklist">
            {boss.dpsActions.map(action => (
              <li class="checklist-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span>{action}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- РЛ -->
        <div class="role-card card-rl" data-card-role="rl">
          <div class="role-card-header">
            <div class="role-icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2-2 0-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.25z"/></svg>
            </div>
            <h3 class="role-card-title">Рейд-лидер (РЛ)</h3>
          </div>
          <ul class="checklist">
            {boss.rlNotes.map(action => (
              <li class="checklist-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                <span>{action}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Раздел классовых хитростей -->
      {boss.classTricks && boss.classTricks.length > 0 && (
        <div style="margin-top: 40px;">
          <h2 class="section-heading">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-rl)" xmlns="http://www.w3.org/2000/svg" style="vertical-align: middle; margin-right: 10px;">
              <path d="M9 21c0 .55.45 1 1 1h4c.55 0 1-.45 1-1v-1H9v1zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7zm2.85 11.1l-.85.6V16h-4v-2.3l-.85-.6C7.8 12.16 7 10.63 7 9c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.63-.8 3.16-2.15 4.1z"/>
            </svg>
            Классовые хитрости и фишки
          </h2>
          <div class="role-card card-rl" style="border-top: 4px solid var(--color-rl);">
            <ul class="checklist">
              {boss.classTricks.map(trick => (
                <li class="checklist-item">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-rl)" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                  </svg>
                  <span>{trick}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      )}

    </div>
  </main>
</Layout>

<script>
  // Клиентское переключение вкладок ролей
  const tabButtons = document.querySelectorAll('.role-tab-btn');
  const roleCards = document.querySelectorAll('[data-card-role]');

  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      // Сброс активного класса со всех кнопок
      tabButtons.forEach(b => b.classList.remove('active'));
      // Добавление активного класса на нажатую
      btn.classList.add('active');
      
      const role = btn.getAttribute('data-role');
      
      roleCards.forEach(card => {
        const cardRole = card.getAttribute('data-card-role');
        const element = card as HTMLElement;
        if (role === 'all' || cardRole === role) {
          element.style.display = 'block';
        } else {
          element.style.display = 'none';
        }
      });
    });
  });
</script>
